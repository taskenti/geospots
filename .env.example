POSTGRES_DB=geospots
POSTGRES_USER=geospots
POSTGRES_PASSWORD=geospots_prod_2026
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Provider activo del pipeline LLM (claim extraction, intent, summary).
# - "gemini"  → uso diario (free tier 1500 req/día) con gemini-2.5-flash-lite
# - "deepseek"→ bulk inicial por país (~$0.14/M input, $0.28/M output)
ENRICHMENT_PROVIDER=gemini
GEMINI_ENRICHMENT_MODEL=gemini-2.5-flash-lite
DEEPSEEK_ENRICHMENT_MODEL=deepseek-v4-flash
API_SECRET_KEY=your_api_secret_key_here
# StayFree - API privada (opcional, sin esto fallback a API publica sin coordenadas)
# STAYFREE_AUTHORIZATION: JWT del usuario (Bearer xxx) - copiar de DevTools tras login
# STAYFREE_API_TOKEN: token estatico de la app movil - capturar via MITM del APK
# Si reciben 401/403/419 durante un scrape, el log muestra instrucciones detalladas
STAYFREE_AUTHORIZATION=
STAYFREE_API_TOKEN=

# ── Google Maps Places API (New) — enriquecimiento dirigido de contacto ──
# Clave de Google Cloud con "Places API (New)" habilitada y FACTURACIÓN activa
# (sin facturación las llamadas devuelven error aunque uses el crédito de $200/mes).
# Configura presupuesto + cuotas diarias en la consola de GCP para evitar sorpresas.
GOOGLE_MAPS_API_KEY=
# Spots a enriquecer por run (controla el gasto: ~$49/1000 spots con 2 llamadas/spot;
# $200/mes ≈ 4080 spots/mes ≈ 135/día).
GOOGLE_MAPS_DAILY_BUDGET=135
# Días antes de reintentar un spot ya consultado (match o sin match).
GOOGLE_REFRESH_DAYS=30
# Umbrales de match para aceptar un place de Google como el mismo POI físico.
GOOGLE_MATCH_DISTANCE_M=150
GOOGLE_MATCH_NAME_SIM=0.6
# Delay entre requests HTTP (segundos).
GOOGLE_MAPS_RATE_LIMIT=0.2

# ── Motor geoespacial OSM (Sprint 3 — piloto Overpass) ──
# Calcula proximidad (agua, vaciado, súper, gasolinera, farmacia, mirador) por spot.
GEO_OSM_COUNTRY=es          # país piloto
GEO_OSM_BATCH=300           # spots por run (Overpass es frágil: empezar bajo)
GEO_OSM_RADIUS_M=3000       # radio de búsqueda en metros
GEO_OSM_RATE=1.5            # delay entre queries (s) — respetar Overpass público
GEO_OSM_REFRESH_DAYS=180    # TTL antes de recomputar un spot
# OVERPASS_URL=https://overpass-api.de/api/interpreter   # endpoint (default público)
